# =============================================================================
# Ship bathymetry repo - root .gitignore
#
# Repo total: ~382 GB on disk. Tracked content target: < 50 MB.
# Heavy data is either re-downloadable or regenerable; do not commit it.
# =============================================================================

# ---------------------------------------------------------------------------
# Heavy data dirs (raw inputs, derived outputs, source archives)
# ---------------------------------------------------------------------------
**/raw/
**/derived/
**/archive/
JAMSTEC/bathymetry_data/
JAMSTEC/gravity_data/
NCEI_singlebeam/singlebeam.xyz

# ---------------------------------------------------------------------------
# Generic binary / data formats - never commit
# ---------------------------------------------------------------------------
*.parquet
*.zip
*.rar
*.7z
*.tar
*.tar.gz
*.tgz
*.nc
*.npz
*.npy
*.pkl
*.pickle
*.h5
*.hdf5
*.feather

# ---------------------------------------------------------------------------
# Logs and runtime artifacts
# ---------------------------------------------------------------------------
**/output/logs/
*.log
*.nohup.log
*.pid
*.tmp

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Editor / OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Trained model artifacts (Step 11 baselines)
# ---------------------------------------------------------------------------
**/baselines_*/
*.joblib
*.bin
*.model
*.lgbm
*.xgb
